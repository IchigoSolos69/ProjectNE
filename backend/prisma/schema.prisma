datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Product {
  id               String      @id @default(uuid()) @db.Uuid
  name             String
  description      String
  price            Int         // Stored in paise for Razorpay integration (smallest currency unit)
  sku              String      @unique
  inventoryCount   Int
  category         String
  imageUrl         String
  isActive         Boolean     @default(true)
  sizes            String[]    // Supported sizes (e.g. Twin, Queen, King)
  features         String[]    // Bulleted selling points
  materials        String?     // Details & Materials text
  careInstructions String?     // Care instructions text
  orderItems       OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  user              User        @relation(fields: [userId], references: [id])
  totalAmount       Int         // Stored in paise for Razorpay
  status            OrderStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  delhiveryAwb      String?     // Tracking reference for Delhivery integration
  shippingAddress   String      // Shipping destination detail
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @db.Uuid
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String   @db.Uuid
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int
  priceAtPurchase Int      // Price at time of purchase in paise
}
